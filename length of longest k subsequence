class Solution:
    def lengthOfLongestSubstringKDistinct(self, s: str, k: int) -> int:
        from collections import defaultdict
        left=0
        freq=defaultdict(int)
        maxi=0

        for right in range(len(s)):
            freq[s[right]]+=1

            while len(freq)>k:
                freq[s[left]]-=1
                if freq[s[left]]==0:
                    del freq[s[left]]
                left+=1 
            maxi=max(maxi, right-left+1)
        return maxi
