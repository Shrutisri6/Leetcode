class Solution:
    def backtrack(self, board, word, visited, i, j, ind):
        if i < 0 or j < 0 or i >= len(board) or j >= len(board[0]):
            return False
        
        if visited[i][j] == 1 or board[i][j] != word[ind]:
            return False

        if ind == len(word) - 1:
            return True

        visited[i][j] = 1

        if (self.backtrack(board, word, visited, i+1, j, ind+1) or
            self.backtrack(board, word, visited, i-1, j, ind+1) or
            self.backtrack(board, word, visited, i, j+1, ind+1) or
            self.backtrack(board, word, visited, i, j-1, ind+1)):
            return True

        visited[i][j] = 0
        return False

    def exist(self, board, word):
        for i in range(len(board)):
            for j in range(len(board[0])):
                visited = [[0]*len(board[0]) for _ in range(len(board))]
                if self.backtrack(board, word, visited, i, j, 0):
                    return True
        return False
