class Solution:
    def shortestToChar(self, s: str, c: str) -> List[int]:
        answer=[]
        indexes=[]
        for i in range(len(s)):
            if s[i]==c:
                indexes.append(i)
        for i in range(len(s)):
            mini=float('inf')
            for j in indexes:
                if abs(i-j)<mini:
                    mini=abs(i-j)
            answer.append(mini)
        return answer
            
