class Solution:
    def totalFruit(self, fruits: List[int]) -> int:
        from collections import defaultdict
        left=0
        d=defaultdict(int)
        maxi=0

        for right in range(len(fruits)):
            d[fruits[right]]+=1

            if len(d)>2:
                d[fruits[left]]-=1
                if d[fruits[left]]==0:
                    del d[fruits[left]]
                left+=1
            
            if right-left+1>maxi:
                maxi=right-left+1
        return maxi
